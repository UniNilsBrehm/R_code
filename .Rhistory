file_dir <- "D:/WorkingData/Susana/SPZ_ISI60_removed_non_responders_2stimuli.csv"
res <- load_data_darkflash_60s(file_dir, move_th = 0, take_peak = 0)
df_final     <- res$df_final
df_final_sub <- res$df_final_sub
# Number of animals per genotype
n_per_genotype <- df_final %>%
distinct(Video, Well, Genotype) %>%
count(Genotype)
print(n_per_genotype)
# Prepare model data:
# t = Stimulus_New - 1 so that t=0 at stimulus 1
# This guarantees P(respond) = 1.0 at t=0 by construction,
# consistent with the selection criterion (only fish that responded
# to stimulus 1 are included)
df_model <- df_final %>%
mutate(t = Stimulus_New - 1)
# s(t) = a smooth function of stimulus number
# by = ... = fit a separate smooth per group
# bs = "re" = random effect (special smoother)
# k = knots = controls wiggliness (complexity ceiling)
# Simple version first — one smooth per genotype, shared across blocks
m_gamm_simple <- bam(
move ~ Genotype + Block +
s(t, by = Genotype, k = 10) +  # separate curve per genotype
s(Video, bs = "re") +           # random intercept per session
s(Well, bs = "re"),             # random intercept per animal
family   = binomial(link = "logit"),
data     = df_model,
method   = "fREML",   # fast REML — best for large datasets
discrete = TRUE       # further speedup for large n
)
# Create interaction factor for genotype x block
df_model <- df_model %>%
mutate(GenoBlock = interaction(Genotype, Block, drop = TRUE))
m_gamm <- bam(
move ~ GenoBlock +                          # parametric intercepts
s(t, by = GenoBlock, k = 10) +       # separate smooth per genotype x block
s(Video, bs = "re") +                # random intercept per session (5 levels)
s(Well, bs = "re"),                  # random intercept per animal
family   = binomial(link = "logit"),
data     = df_model,
method   = "fREML",
discrete = TRUE,
nthreads = 4        # use multiple cores — bam() supports this
)
# k' should be well below k (edf should not be near k-1)
# If edf ≈ k-1, increase k
k.check(m_gamm)
# Output looks like:
#                           k'  edf k-index p-value
# s(t):GenoBlockABTL.Block1  9 3.21    1.02    0.49
# ...
# edf of 3.21 with k'=9 is fine — plenty of room
# If edf were 8.5 with k'=9, increase k to 15
# --- Option 1: Quick base plot via gratia ---
draw(m_gamm, select = starts_with("s(t)"))
