response ~ pinf + (p0 - pinf) * exp(-stimulus / tau),
p0 + pinf + tau ~ drug_condition + (1 | plate_id/fish_id),
nl = TRUE
)
priors <- c(
prior(normal(0, 1.5), nlpar = "p0", lb = 0, ub = 1),
prior(normal(0, 1.5), nlpar = "pinf", lb = 0, ub = 1),
prior(lognormal(1, 0.5), nlpar = "tau"),
prior(exponential(1), class = "sd")
)
