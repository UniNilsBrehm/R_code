nl_formula_fixed_only <- bf(
# Response variable: prob is the binomial response (0 or 1).
# trials(1) specifies a binary outcome (1 trial per observation).
prob | trials(1) ~ A + B * exp(-k * stimulus_number),
# Define the linear models for the non-linear parameters (A, B, k)
A ~ 1, # Simple intercept for Asymptote A
B ~ 1, # Simple intercept for Magnitude B
# KEY SIMPLIFICATION: k is modeled only by fixed effects (Block * drug_condition)
# The random effect term +(1 | plate_id/fish_id) has been REMOVED for speed.
k ~ 0 + Block * drug_condition,
nl = TRUE, # Flag this as a non-linear formula
# Using 'identity' link for a direct probability model (can be numerically challenging,
# but is the most direct fit to the theoretical exponential decay P).
family = binomial(link = "identity")
)
# 2. Fit the Model with REDUCED SAMPLING LOAD
#    The goal is speed, not final accuracy.
m_nl_brms_quick_test <- brm(
nl_formula_fixed_only,
data = df_halo,
# --- Reduced Sampling Settings ---
chains = 2,           # Use only 2 independent chains
iter = 500,           # Drastically reduce total iterations
warmup = 100,         # Reduce the burn-in phase
cores = 2,            # Match cores to chains for parallel execution
# This control setting is often necessary for complex NL-GLMMs to sample correctly
control = list(adapt_delta = 0.95),
# Use 'silent = 2' to suppress most progress messages and further speed up the run
silent = 2
)
nl_formula_fixed_only <- bf(
# Response variable: prob is the binomial response (0 or 1).
# trials(1) specifies a binary outcome (1 trial per observation).
prob | trials(1) ~ A + B * exp(-k * stimulus),
# Define the linear models for the non-linear parameters (A, B, k)
A ~ 1, # Simple intercept for Asymptote A
B ~ 1, # Simple intercept for Magnitude B
# KEY SIMPLIFICATION: k is modeled only by fixed effects (Block * drug_condition)
# The random effect term +(1 | plate_id/fish_id) has been REMOVED for speed.
k ~ 0 + Block * drug_condition,
nl = TRUE, # Flag this as a non-linear formula
# Using 'identity' link for a direct probability model (can be numerically challenging,
# but is the most direct fit to the theoretical exponential decay P).
family = binomial(link = "identity")
)
# 2. Fit the Model with REDUCED SAMPLING LOAD
#    The goal is speed, not final accuracy.
m_nl_brms_quick_test <- brm(
nl_formula_fixed_only,
data = df_halo,
# --- Reduced Sampling Settings ---
chains = 2,           # Use only 2 independent chains
iter = 500,           # Drastically reduce total iterations
warmup = 100,         # Reduce the burn-in phase
cores = 2,            # Match cores to chains for parallel execution
# This control setting is often necessary for complex NL-GLMMs to sample correctly
control = list(adapt_delta = 0.95),
# Use 'silent = 2' to suppress most progress messages and further speed up the run
silent = 2
)
